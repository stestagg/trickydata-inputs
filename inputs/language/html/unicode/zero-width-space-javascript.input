name: language_html_data_zero_width_space_javascript
description: |
  U+200B ZERO WIDTH SPACE visually splits the JavaScript scheme without obvious
  width. Browsers do not generally remove it as URL whitespace, but filters,
  search tools, and custom normalizers may, creating a dangerous validation and
  canonicalization differential.
format: utf8-strip
decode-as: utf8
unicode-meta:
  code-units: 14
  code-points: 12
  scalar-values: 12
  legacy-grapheme-clusters: 12
  extended-grapheme-clusters: 12
tags:
  - "language"
  - "html"
  - "xss"
  - "xss-data"
  - "utf8"
  - "url-context"
  - "javascript-url"
  - "zero-width-space"
  - "canonicalization"
  - "text-spoofing"
---
java​script:

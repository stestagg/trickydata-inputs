name: language_html_data_script_double_quote
description: |
  Double quote terminates a double-quoted JavaScript string. This catches
  renderers that select HTML attribute or text encoding despite emitting data
  into JavaScript source.
format: utf8-strip
decode-as: ascii
tags:
  - "language"
  - "html"
  - "xss"
  - "xss-data"
  - "script-context"
  - "javascript-string"
  - "double-quote"
  - "contextual-escaping"
---
"

name: language_html_data_script_paragraph_separator
description: |
  U+2029 PARAGRAPH SEPARATOR stresses the same generated-source boundary as
  U+2028, including legacy JavaScript parsers, JSON-to-script embedding,
  minification, and error-location reporting.
format: hex
decode-as: utf8
unicode-meta:
  code-units: 3
  code-points: 1
  scalar-values: 1
  legacy-grapheme-clusters: 1
  extended-grapheme-clusters: 1
tags:
  - "language"
  - "html"
  - "xss"
  - "xss-data"
  - "script-context"
  - "javascript-string"
  - "paragraph-separator"
  - "unicode"
---
e2 80 a9   # U+2029 PARAGRAPH SEPARATOR

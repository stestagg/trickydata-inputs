name: language_html_data_script_line_separator
description: |
  U+2028 LINE SEPARATOR has historically differed between JSON, JavaScript
  string literals, minifiers, and line-oriented tooling. It can split generated
  source or produce a syntax error in older parsers if not serialized safely.
format: hex
decode-as: utf8
unicode-meta:
  code-units: 3
  code-points: 1
  scalar-values: 1
  legacy-grapheme-clusters: 1
  extended-grapheme-clusters: 1
tags:
  - "language"
  - "html"
  - "xss"
  - "xss-data"
  - "script-context"
  - "javascript-string"
  - "line-separator"
  - "unicode"
---
e2 80 a8   # U+2028 LINE SEPARATOR

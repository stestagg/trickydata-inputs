name: language_html_data_harmless_element
description: |
  This inert custom-element tag is a visible canary for raw HTML interpretation.
  Correct text insertion displays the angle brackets; unsafe innerHTML or
  template interpolation creates an x-xss-canary DOM element without executing
  script or loading a resource.
format: utf8-strip
decode-as: ascii
pair:
  - with: ../unicode/fullwidth-angle-element.input
    hint: tricky
  - with: ../unicode/small-angle-element.input
    hint: tricky
tags:
  - "language"
  - "html"
  - "xss"
  - "xss-data"
  - "html-text-context"
  - "custom-element"
  - "dom-injection"
  - "inert-canary"
---
<x-xss-canary>

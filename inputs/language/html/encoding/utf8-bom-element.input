name: language_html_data_utf8_bom_element
description: |
  U+FEFF precedes an inert element canary. Layers may strip it as a byte-order
  mark only at the start of a buffer, preserve it as application data, or move
  the value between positions where its treatment changes.
format: hex
decode-as: utf8
unicode-meta:
  code-units: 17
  code-points: 15
  scalar-values: 15
  legacy-grapheme-clusters: 15
  extended-grapheme-clusters: 15
tags:
  - "language"
  - "html"
  - "xss"
  - "xss-data"
  - "utf8"
  - "byte-order-mark"
  - "encoding"
  - "normalization"
  - "inert-canary"
---
ef bb bf "<x-xss-canary>"

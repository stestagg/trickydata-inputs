name: language_sql_data_fullwidth_apostrophe_name
description: |
  U+FF07 FULLWIDTH APOSTROPHE normalizes to ASCII apostrophe under NFKC. Systems
  that normalize after escaping or validation can introduce an SQL delimiter
  that was not present in the checked input.
format: utf8-strip
decode-as: utf8
unicode-meta:
  code-units: 10
  code-points: 8
  scalar-values: 8
  legacy-grapheme-clusters: 8
  extended-grapheme-clusters: 8
tags:
  - "language"
  - "sql"
  - "sql-data"
  - "utf8"
  - "apostrophe"
  - "fullwidth"
  - "nfkc"
  - "normalization"
  - "injection-canary"
---

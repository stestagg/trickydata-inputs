name: language_sql_data_apostrophe_name
description: |
  A realistic name containing an apostrophe catches unsafe interpolation and
  overzealous rejection without looking like a synthetic attack string.
  Correct parameter binding should preserve the exact eight-character value.
format: utf8-strip
decode-as: ascii
pair:
  - with: ../unicode/curly-apostrophe-name.input
    hint: tricky
  - with: ../unicode/fullwidth-apostrophe-name.input
    hint: tricky
tags:
  - "language"
  - "sql"
  - "sql-data"
  - "string"
  - "single-quote"
  - "escaping"
  - "parameter-binding"
  - "realistic"
---
O'Reilly
